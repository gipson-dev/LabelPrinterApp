{
    "tasks": [
        {
            "type": "shell",
            "label": "Build LabelPrinterApp",
            "command": "powershell.exe",
            "args": [
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}\\scripts\\build-and-test.ps1"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Configures, builds, and tests with CMake. The script finds Visual Studio's bundled CMake when it is not on PATH."
        }
    ],
    "version": "2.0.0"
}
